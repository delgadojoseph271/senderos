                                    },
                                    "date": {
                                        "type": "string",
                                        "format": "date-time"
                                    },
                                    "pax": {
                                        "type": "integer",
                                        "minimum": 1,
                                        "maximum": 20
                                    },
                                    "notes": {
                                        "type": [
                                            "string",
                                            "null"
                                        ],
                                        "maxLength": 500
                                    }
                                },
                                "required": [
                                    "route_id",
                                    "guide_id",
                                    "date",
                                    "pax"
                                ]
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "`BookingResource`",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/BookingResource"
                                }
                            }
                        }
                    },
                    "422": {
